@@ -116,9 +116,25 @@ namespace CGeneral { // More like `Math` (Or `Meth`, given how bad the code is,
      * @param max Maximum value. Must be greater than min.
      * @return A pseudo-random number between min and max, exclusive [min, max).
      */
+    // x87 FPU helper matching original at 0x407180 — 80-bit precision with
+    // fisttp truncation avoids SSE 32-bit rounding mismatches.
+    inline int32 _GetRandomNumberInRange_x87(int32 min_val, int32 max_val) {
+        static const float recip = 1.0f / 32768.0f;
+        int32 rnd = static_cast<int32>(GetRandomNumber());
+        int32 range = max_val - min_val;
+        int32 scaled;
+        __asm {
+            fild    dword ptr [rnd]
+            fmul    dword ptr [recip]
+            fimul   dword ptr [range]
+            fisttp  dword ptr [scaled]
+        }
+        return min_val + scaled;
+    }
+
     template<std::integral T>
     inline T GetRandomNumberInRange(T min, T max) {
-        return static_cast<T>(GetRandomNumberInRange<float>(static_cast<float>(min), static_cast<float>(max) - 1.f)); // substraction in floating point because integer might underflow (if unsigned)
+        return static_cast<T>(_GetRandomNumberInRange_x87(static_cast<int32>(min), static_cast<int32>(max)));
     }
 
