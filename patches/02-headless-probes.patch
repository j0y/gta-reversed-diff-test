+// Helper: append to C:\loadlevel.log
+static void LLLog(const char* msg) {
+    HANDLE h = CreateFileA("C:\\loadlevel.log", FILE_APPEND_DATA,
+                           FILE_SHARE_READ | FILE_SHARE_WRITE,
+                           NULL, OPEN_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
+    if (h != INVALID_HANDLE_VALUE) {
+        char buf[512];
+        int len = wsprintfA(buf, "[%lu] %s\r\n", GetTickCount(), msg);
+        DWORD written;
+        WriteFile(h, buf, len, &written, NULL);
+        CloseHandle(h);
+    }
+}
